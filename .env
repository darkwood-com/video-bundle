# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> video/replicate ###
# 1 = only scene 1 uses real video/voice when Replicate is enabled; 0 = all scenes use real.
VIDEO_REAL_FOR_FIRST_SCENE_ONLY=1

# 1 = parallel scene pipelines (Spatie Fork, requires pcntl) and parallel voice+video when both are non-empty; 0 = sequential.
VIDEO_PARALLEL_FORK=1

# Max concurrent scene pipelines (Fork). Lower = gentler on Replicate; rate limiter also applies.
VIDEO_MAX_PARALLEL_SCENES=4

# Replicate API sliding-window limits (requests per rolling minute, file-backed across processes).
VIDEO_REPLICATE_RATE_PREDICTIONS_PER_MINUTE=580
VIDEO_REPLICATE_RATE_OTHER_PER_MINUTE=2800

# Replicate video provider (HTTP API) configuration.
# DO NOT put real tokens in committed files; override in .env.local or real env.
VIDEO_VIDEO_REPLICATE_ENABLED=0
VIDEO_VIDEO_REPLICATE_API_TOKEN=
# Example: model or version identifier as required by Replicate
VIDEO_VIDEO_REPLICATE_MODEL=
# Optional default preset key when calls omit replicate_preset (see ReplicateVideoModelPresets)
VIDEO_VIDEO_REPLICATE_DEFAULT_PRESET=
# Polling interval (seconds) between prediction status checks. 3–5s is a reasonable default for Replicate “other” API limits.
VIDEO_VIDEO_REPLICATE_POLL_INTERVAL_SECONDS=5
# Maximum number of polling attempts before giving up
VIDEO_VIDEO_REPLICATE_MAX_ATTEMPTS=60
# Wall-clock poll cap in seconds (0 = only max_attempts applies)
VIDEO_VIDEO_REPLICATE_POLL_TIMEOUT_SECONDS=0

# Replicate voice (MiniMax Speech 2.6 Turbo). Uses VIDEO_VIDEO_REPLICATE_API_TOKEN when enabled.
# voice_id must be a valid MiniMax catalogue voice (see Replicate model API tab); placeholders like TON_VOICE_ID are rejected at startup.
VIDEO_VOICE_REPLICATE_ENABLED=0
VIDEO_VOICE_REPLICATE_MODEL=minimax/speech-2.6-turbo
VIDEO_VOICE_REPLICATE_VOICE_ID=
VIDEO_VOICE_REPLICATE_AUDIO_FORMAT=mp3
###< video/replicate ###
