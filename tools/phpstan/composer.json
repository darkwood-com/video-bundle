{
    "require": {
        "php": ">=8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "darkwood/flow": "^1.2",
        "spatie/fork": "^1.2",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "symfony/phpunit-bridge": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "../../src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "../../tests"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/runtime": false,
            "symfony/flex": false
        }
    }
}
